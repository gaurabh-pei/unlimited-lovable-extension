{
  "manifest_version": 3,
  "name": "Maxx's Lovable",
  "version": "1.2.0",
  "description": "Companion extension for Lovable.dev with license, analytics, and prompt asset uploads.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "https://*.lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://lovable.dev/*",
    "https://lovable-api.com/*",
    "https://unlimitedprompts.lovable.app/*"
  ],
  "action": {
    "default_title": "Maxx's Lovable",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ],
      "js": [
        "pageHook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*",
        "https://api.lovable.dev/*"
      ],
      "js": [
        "extension-config.js",
        "lovable-auth.js",
        "lovable-feature-api.js",
        "user-messages.js",
        "jszip.min.js",
        "content-bridge.js",
        "sounds.js"
      ],
      "css": [
        "theme.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pageHook.js",
        "sounds/error-ratelimit.mp3",
        "sounds/error-token.mp3",
        "assets/logo-master-lovable.png",
        "assets/logo-master-lovable-square.png",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": [
        "https://*.lovable.dev/*",
        "https://lovable.dev/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
